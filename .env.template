# Marco the Nomad - Environment Config

# Required
ANTHROPIC_API_KEY=

# Optional: Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: LI.FI API key (higher rate limits)
LIFI_API_KEY=

# LIVE mode only (DEMO_MODE=false)
# SECURITY: Marco validates the private key at startup and verifies it
# matches WALLET_ADDRESS. If WALLET_ADDRESS is empty, it's auto-derived.
# Never commit your private key. Use a dedicated hot wallet with limited funds.
WALLET_ADDRESS=
WALLET_PRIVATE_KEY=

# Agent behavior
DEMO_MODE=true
SCAN_CHAINS=8453,42161,10,137
MIN_TVL_USD=500000
MIN_APY=3.0
MAX_BRIDGE_COST_PCT=2.0
POSITION_SIZE_USD=100
LOOP_INTERVAL=3600
MIN_CONFIDENCE=0.6
SLIPPAGE=0.005
BRAIN_MODEL=claude-sonnet-4-20250514
