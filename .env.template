# Marco the Nomad - Environment Config

# Required
ANTHROPIC_API_KEY=

# Optional: Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: LI.FI API key (higher rate limits)
LIFI_API_KEY=

# Wallet: auto-created at ~/.marco/wallet.json on first run.
# Or set manually (key validated at startup, address auto-derived if empty).
# Never commit your private key. Use a dedicated hot wallet with limited funds.
WALLET_ADDRESS=
WALLET_PRIVATE_KEY=

# Withdrawal security: comma-separated list of addresses that can receive funds
# Only these addresses are allowed as /withdraw targets
OWNER_ADDRESSES=

# Agent behavior
FAST_BRAIN=true
SCAN_CHAINS=8453,42161,10,137
MIN_TVL_USD=500000
MIN_APY=3.0
MAX_BRIDGE_COST_PCT=2.0
POSITION_SIZE_USD=100
LOOP_INTERVAL=3600
MIN_CONFIDENCE=0.6
SLIPPAGE=0.005
BRAIN_MODEL=claude-sonnet-4-20250514
